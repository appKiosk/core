# Local overrides for a single developer machine.
# Copy to .env.local and adjust values as needed.

CORE_LOG_LEVEL=debug
CORE_GATEWAY_PUBLIC_URL=http://localhost:8080
CORE_KEYCLOAK_BASE_URL=http://localhost:8081
# Set a real local-only secret value in .env.local.
CORE_KEYCLOAK_CLIENT_SECRET=replace-me
CORE_TENANT_ID=dev-tenant