# Core platform environment template
# Copy to .env.local for machine-specific values.

CORE_ENVIRONMENT=development
CORE_LOG_LEVEL=info

# Public host shell and gateway entrypoints
CORE_HOST_SHELL_PUBLIC_URL=http://localhost:4200
CORE_GATEWAY_PUBLIC_URL=http://localhost:8080

# Core service API endpoints
CORE_REGISTRY_API_URL=http://localhost:4101
CORE_POLICY_API_URL=http://localhost:4102
CORE_ENTITLEMENT_API_URL=http://localhost:4103
CORE_VALIDATION_API_URL=http://localhost:4104
CORE_AUDIT_API_URL=http://localhost:4105

# Authentication and tenant defaults
CORE_KEYCLOAK_BASE_URL=http://localhost:8081
CORE_KEYCLOAK_USER_REALM=core-users
CORE_KEYCLOAK_SERVICE_REALM=core-services
CORE_KEYCLOAK_CLIENT_ID=core-local-dev
CORE_KEYCLOAK_CLIENT_SECRET=replace-me
CORE_TENANT_ID=dev-tenant

# Shared behavior tuning
CORE_PLUGIN_MANIFEST_CACHE_TTL_SECONDS=30
CORE_REQUEST_TIMEOUT_MS=10000