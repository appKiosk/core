{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "format": "npm exec nx -- format:write",
    "format:check": "npm exec nx -- format:check --base=remotes/origin/main",
    "lint": "npm exec nx -- run-many -t lint",
    "test": "npm exec nx -- run-many -t test",
    "build": "npm exec nx -- run-many -t build",
    "typecheck": "npm exec nx -- run-many -t typecheck",
    "dev:keycloak:up": "podman start core-keycloak >/dev/null 2>&1 || podman-compose -f docker-compose.yml up -d keycloak && npm run dev:keycloak:migrate",
    "dev:keycloak:migrate": "podman run --rm --network core_default --env-file .env -e KEYCLOAK_URL=http://keycloak:8080 -v $PWD/infra/keycloak/migrations:/opt/keycloak-data/migrations:ro --entrypoint /bin/sh quay.io/keycloak/keycloak:26.2 /opt/keycloak-data/migrations/apply-migrations.sh",
    "dev:keycloak:down": "podman-compose -f docker-compose.yml down -v",
    "dev:keycloak:logs": "podman-compose -f docker-compose.yml logs -f keycloak",
    "check:lockfile-sync": "npx --yes npm@10.8.2 install --package-lock-only --ignore-scripts --no-audit --no-fund && git diff --exit-code -- package-lock.json",
    "check:format-staged": "files=$(git diff --cached --name-only --diff-filter=ACMR | paste -sd, -) && [ -z \"$files\" ] || npm exec nx -- format:check --files=\"$files\"",
    "prepare": "simple-git-hooks"
  },
  "private": true,
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@nx/js": "22.7.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/node": "20.19.9",
    "eslint": "^9.35.0",
    "globals": "^15.15.0",
    "nx": "22.7.2",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check:lockfile-sync && npm run check:format-staged"
  },
  "workspaces": [
    "packages/*"
  ]
}
